        "# Sistema de Análise de Dados + Calculadora\n",
        "# Autor: Matheus Nikolay\n",
        "\n",
        "import pandas as pd\n",
        "\n",
        "def carregar_planilha():\n",
        "    print(\"\\n=== CARREGAR PLANILHA ===\")\n",
        "    print(\"1 - Usar arquivo Excel\")\n",
        "    print(\"2 - Usar dados de exemplo\")\n",
        "\n",
        "    escolha = input(\"Escolha: \")\n",
        "\n",
        "    if escolha == \"1\":\n",
        "        try:\n",
        "            arquivo = input(\"Digite o nome do arquivo (ex: Produtos.xlsx): \")\n",
        "            planilha = pd.read_excel(arquivo)\n",
        "\n",
        "            print(\"\\nPlanilha carregada com sucesso!\")\n",
        "            print(planilha.head())\n",
        "\n",
        "        except FileNotFoundError:\n",
        "            print(\"❌ Arquivo não encontrado! Coloque o Excel na mesma pasta.\")\n",
        "        except Exception as e:\n",
        "            print(\"❌ Erro:\", e)\n",
        "\n",
        "    elif escolha == \"2\":\n",
        "        print(\"\\nUsando dados de exemplo...\")\n",
        "\n",
        "        dados = {\n",
        "            \"Produto\": [\"Mouse\", \"Teclado\", \"Monitor\"],\n",
        "            \"Preço\": [50, 100, 800],\n",
        "            \"Quantidade\": [10, 5, 2]\n",
        "        }\n",
        "\n",
        "        planilha = pd.DataFrame(dados)\n",
        "        print(planilha)\n",
        "\n",
        "    else:\n",
        "        print(\"Opção inválida!\")\n",
        "\n",
        "def calculadora():\n",
        "    print(\"\\n=== CALCULADORA ===\")\n",
        "    print(\"1 - Soma\")\n",
        "    print(\"2 - Subtração\")\n",
        "    print(\"3 - Multiplicação\")\n",
        "    print(\"4 - Divisão\")\n",
        "\n",
        "    opcao = input(\"Escolha: \")\n",
        "\n",
        "    num1 = float(input(\"Digite o primeiro número: \"))\n",
        "    num2 = float(input(\"Digite o segundo número: \"))\n",
        "\n",
        "    if opcao == \"1\":\n",
        "        print(\"Resultado:\", num1 + num2)\n",
        "    elif opcao == \"2\":\n",
        "        print(\"Resultado:\", num1 - num2)\n",
        "    elif opcao == \"3\":\n",
        "        print(\"Resultado:\", num1 * num2)\n",
        "    elif opcao == \"4\":\n",
        "        if num2 != 0:\n",
        "            print(\"Resultado:\", num1 / num2)\n",
        "        else:\n",
        "            print(\"Erro: divisão por zero!\")\n",
        "    else:\n",
        "        print(\"Opção inválida!\")\n",
        "\n",
        "def dados_usuario():\n",
        "    nome = input(\"\\nDigite seu nome: \")\n",
        "    idade = int(input(\"Digite sua idade: \"))\n",
        "    altura = float(input(\"Digite sua altura: \"))\n",
        "\n",
        "    print(f\"\\nNome: {nome}\")\n",
        "    print(f\"Idade: {idade}\")\n",
        "    print(f\"Altura: {altura:.2f}\")\n",
        "\n",
        "def menu():\n",
        "    while True:\n",
        "        print(\"\\n===== MENU =====\")\n",
        "        print(\"1 - Carregar planilha\")\n",
        "        print(\"2 - Calculadora\")\n",
        "        print(\"3 - Dados do usuário\")\n",
        "        print(\"0 - Sair\")\n",
        "\n",
        "        opcao = input(\"Escolha: \")\n",
        "\n",
        "        if opcao == \"1\":\n",
        "            carregar_planilha()\n",
        "        elif opcao == \"2\":\n",
        "            calculadora()\n",
        "        elif opcao == \"3\":\n",
        "            dados_usuario()\n",
        "        elif opcao == \"0\":\n",
        "            print(\"Encerrando...\")\n",
        "            break\n",
        "        else:\n",
        "            print(\"Opção inválida!\")\n",
        "\n",
        "# Executar sistema\n",
        "menu()"
      ],
